# Environment Configuration for Trendify E-Commerce System
# Copy this file to .env.local and fill in your actual values

# API Configuration
# Note: In Next.js, NEXT_PUBLIC_ prefix makes variables accessible on the client side
NEXT_PUBLIC_API_URL=https://your-mockapi-endpoint.mockapi.io
NEXT_PUBLIC_PRODUCTS_URL=https://your-mockapi-endpoint.mockapi.io/product
NEXT_PUBLIC_CATEGORIES_URL=https://your-mockapi-endpoint.mockapi.io/categories
NEXT_PUBLIC_FAQS_URL=https://your-mockapi-endpoint.mockapi.io/faqs
NEXT_PUBLIC_TESTIMONIALS_URL=https://your-mockapi-endpoint.mockapi.io/testimonials

# Application Configuration
NEXT_PUBLIC_APP_NAME=Trendify
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_WISHLIST=true
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_ADVANCED_SEARCH=true

# Analytics (Optional - leave empty if not using)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_MIXPANEL_TOKEN=

# Payment Configuration (For future implementation)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Email Service (For future implementation)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_ID=

# Social Media Links
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_TWITTER=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# Support/Contact
NEXT_PUBLIC_SUPPORT_EMAIL=support@trendify.com
NEXT_PUBLIC_CONTACT_PHONE=

# Server-side secrets (these are NOT exposed to the client)
# NEVER commit actual values to version control
# API_SECRET_KEY=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here