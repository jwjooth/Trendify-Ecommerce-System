# Environment Configuration for Trendify E-Commerce System
# Copy this file to .env and fill in your actual values

# API Configuration
VITE_API_URL=https://your-mockapi-endpoint.mockapi.io
VITE_PRODUCTS_URL=https://your-mockapi-endpoint.mockapi.io/product
VITE_CATEGORIES_URL=https://your-mockapi-endpoint.mockapi.io/categories
VITE_FAQS_URL=https://your-mockapi-endpoint.mockapi.io/faqs
VITE_TESTIMONIALS_URL=https://your-mockapi-endpoint.mockapi.io/testimonials

# Application Configuration
VITE_APP_NAME=Trendify
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_ADVANCED_SEARCH=true

# Analytics (Optional - leave empty if not using)
VITE_GOOGLE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=

# Payment Configuration (For future implementation)
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYPAL_CLIENT_ID=

# Email Service (For future implementation)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_USER_ID=

# Social Media Links
VITE_SOCIAL_INSTAGRAM=
VITE_SOCIAL_TWITTER=
VITE_SOCIAL_FACEBOOK=

# Support/Contact
VITE_SUPPORT_EMAIL=support@trendify.com
VITE_CONTACT_PHONE=

# Security (Keep these secret!)
# NEVER commit actual values to version control
# VITE_API_SECRET_KEY=your-secret-key-here
# VITE_JWT_SECRET=your-jwt-secret-here